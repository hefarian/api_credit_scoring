# Environnement de DÉVELOPPEMENT LOCAL
ENVIRONMENT=dev
ENVIRONMENT_NAME=DEV LOCAL
ENVIRONMENT_COLOR=#FF9800
POSTGRES_CONTAINER_NAME=dev_credit_scoring_postgres
API_CONTAINER_NAME=dev_credit_scoring_api
STREAMLIT_CONTAINER_NAME=dev_credit_scoring_streamlit
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=credit_scoring
POSTGRES_PORT=5435
API_PORT=8005
STREAMLIT_PORT=8505

# Configuration API - Communication Streamlit <-> API
# Pour Docker Compose local : utiliser hostname 'api' (le service API dans le réseau Docker)
API_HOST=api
# API_URL peut être défini directement pour les déploiements externes :
# - Conteneur distincte : API_URL=http://localhost:8005/predict
# - VM/Serveur : API_URL=http://192.168.x.x:8005/predict
# - Full URL : API_URL=http://api-server.example.com:8005/predict
API_URL=http://api:8005/predict
