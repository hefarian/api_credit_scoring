# ============================================================================
# Configuration PostgreSQL
# ============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=credit_scoring

# ============================================================================
# Configuration Database Connection String
# ============================================================================
# Configuration Database Connection String
# ============================================================================
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@postgres:5435/credit_scoring

# ============================================================================
# Configuration des alertes
# ============================================================================
# Seuils pour les alertes automatiques
LATENCY_THRESHOLD_MS=1000
ERROR_RATE_THRESHOLD_PCT=5.0
DRIFT_DETECTION_ENABLED=true
